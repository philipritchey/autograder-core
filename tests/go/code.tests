/*
@number: 4.1
@name: unit example
@points: 1
@show_output: True
@type: unit
@target: code.go
@include: testing
*/
<test>
func TestIsPrime(t *testing.T) {
	n := 13
	got := IsPrime(n)
	want := true
	if got != want {
		t.Errorf("IsPrime(%d): got %v want %v", n, got, want)
	}
}
</test>

